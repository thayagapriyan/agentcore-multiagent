legacy-peer-deps=true
# The Strands SDK declares a large peer-dependency set that npm's default hoisting
# splits apart (the SDK hoists to the root, some peers stay nested), breaking ESM
# resolution at runtime. install-strategy=nested keeps each workspace's dependency
# tree under its own node_modules — the SDK resolves its peers locally, mirroring the
# pre-workspace layout that worked, and makes each agent's Docker image self-contained.
install-strategy=nested
